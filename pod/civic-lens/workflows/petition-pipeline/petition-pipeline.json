{
  "name": "petition-pipeline",
  "description": "End-to-end civic issue intake: create petition → classify → draft email → human approval → send",
  "start": { "type": "MANUAL" },
  "nodes": [
    {
      "id": "intake",
      "type": "FORM",
      "label": "Report civic issue",
      "config": {
        "input_schema": {
          "type": "object",
          "properties": {
            "photo_url": { "type": "string", "title": "Photo URL" },
            "description": { "type": "string", "title": "Description" },
            "address": { "type": "string", "title": "Address" },
            "lat": { "type": "number", "title": "Latitude" },
            "lng": { "type": "number", "title": "Longitude" }
          },
          "required": ["photo_url", "lat", "lng"]
        },
        "ui_schema": {
          "ui:order": ["photo_url", "description", "address", "lat", "lng"]
        }
      }
    },
    {
      "id": "create_petition",
      "type": "FUNCTION",
      "label": "Create petition record",
      "config": {
        "function_name": "create_petition",
        "input_mapping": {
          "photo_url": { "type": "expression", "value": "intake.photo_url" },
          "description": { "type": "expression", "value": "intake.description", "optional": true },
          "address": { "type": "expression", "value": "intake.address", "optional": true },
          "lat": { "type": "expression", "value": "intake.lat" },
          "lng": { "type": "expression", "value": "intake.lng" }
        }
      }
    },
    {
      "id": "classify",
      "type": "AGENT",
      "label": "Classify issue & route department",
      "config": {
        "agent_name": "issue-classifier",
        "input_mapping": {
          "petition_id": { "type": "expression", "value": "create_petition.petition_id" },
          "photo_url": { "type": "expression", "value": "intake.photo_url" },
          "description": { "type": "expression", "value": "intake.description", "optional": true },
          "location": { "type": "expression", "value": "intake" }
        }
      }
    },
    {
      "id": "draft_email",
      "type": "AGENT",
      "label": "Draft complaint email",
      "config": {
        "agent_name": "complaint-drafter",
        "input_mapping": {
          "petition_id": { "type": "expression", "value": "create_petition.petition_id" }
        }
      }
    },
    {
      "id": "approval",
      "type": "FORM",
      "label": "Review & approve complaint email",
      "config": {
        "input_schema": {
          "type": "object",
          "properties": {
            "subject": {
              "type": "string",
              "title": "Email subject",
              "default": { "type": "expression", "value": "draft_email.subject", "optional": true }
            },
            "body": {
              "type": "string",
              "title": "Email body",
              "default": { "type": "expression", "value": "draft_email.body", "optional": true }
            },
            "approved": { "type": "boolean", "title": "Send this email?" }
          },
          "required": ["approved"]
        },
        "ui_schema": {
          "body": { "ui:widget": "textarea", "ui:options": { "rows": 12 } },
          "ui:order": ["subject", "body", "approved"]
        }
      }
    },
    {
      "id": "send_email",
      "type": "FUNCTION",
      "label": "Send approved complaint",
      "config": {
        "function_name": "send_complaint_email",
        "input_mapping": {
          "petition_id": { "type": "expression", "value": "create_petition.petition_id" },
          "subject": { "type": "expression", "value": "approval.subject" },
          "body": { "type": "expression", "value": "approval.body" },
          "approved": { "type": "expression", "value": "approval.approved" },
          "to_email": { "type": "expression", "value": "classify.department_email", "optional": true }
        }
      }
    },
    {
      "id": "end",
      "type": "END",
      "label": "Done"
    }
  ],
  "edges": [
    { "id": "e1", "source": "intake", "target": "create_petition" },
    { "id": "e2", "source": "create_petition", "target": "classify" },
    { "id": "e3", "source": "classify", "target": "draft_email" },
    { "id": "e4", "source": "draft_email", "target": "approval" },
    { "id": "e5", "source": "approval", "target": "send_email" },
    { "id": "e6", "source": "send_email", "target": "end" }
  ]
}
