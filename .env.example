# MongoDB (used by FastAPI for images + demo-mode petition storage)
ENVIRONMENT=development
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=urbis

# Lemma — after `lemma auth login` run: ./scripts/lemma-env-hint.sh
# Only LEMMA_REFRESH_TOKEN is required; access tokens refresh automatically.
# LEMMA_TOKEN=
LEMMA_REFRESH_TOKEN=
LEMMA_POD_ID=
LEMMA_ORG_ID=
LEMMA_BASE_URL=https://api.lemma.work
LEMMA_GMAIL_AUTH_CONFIG=workspace-gmail
LEMMA_GMAIL_OPERATION=GMAIL_SEND_EMAIL

# Email — required for authorities to actually receive complaints
# Brevo (recommended, free 300/day): SMTP & API → generate key at app.brevo.com
#   SMTP_HOST=smtp-relay.brevo.com  SMTP_USER=<login@smtp-brevo.com from dashboard>
#   SMTP_FROM must be a verified sender in Brevo → Senders
# Gmail alternative: App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
# Optional: set DEMO_EMAIL_REDIRECT=true to deliver to your inbox instead of the authority (testing only)
DEMO_EMAIL_TO=
DEMO_EMAIL_REDIRECT=false
AUTHORITY_DISCOVERY_ENABLED=true
AUTHORITY_DISCOVERY_TIMEOUT_SECONDS=15
LEMMA_AGENT_TIMEOUT_SECONDS=25
API_BASE_URL=http://localhost:8000

# Escalation threshold in days
ESCALATION_DAYS=3

DUPLICATE_RADIUS_M=500
INFRASTRUCTURE_RADIUS_M=500
SEVERITY_POI_RADIUS_M=500
VISION_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=120
UPLOAD_MAX_BYTES=10485760

# Google OAuth — sign in + send complaints from user's Gmail
# Create at https://console.cloud.google.com → APIs → Gmail API + OAuth client (Web)
# Authorized redirect URI: http://localhost:8000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
FRONTEND_URL=http://localhost:5173
SESSION_SECRET=generate-a-long-random-string-here
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# Production (Vercel frontend + Render API): see docs/DEPLOY.md and .env.production.example
# ENVIRONMENT=production, COOKIE_SECURE=true, COOKIE_SAMESITE=none
# API_BASE_URL=https://your-api.onrender.com
# FRONTEND_URL=https://your-app.vercel.app
CORS_ORIGINS=

# Cloudinary — cloud image storage (recommended for production / Render deploy)
# Dashboard: https://console.cloudinary.com → Account Details
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=urbis
