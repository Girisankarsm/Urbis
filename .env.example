# MongoDB (used by FastAPI for images + demo-mode petition storage)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=urbis

# Lemma — required for AI agents + authority web search
LEMMA_TOKEN=
LEMMA_POD_ID=
LEMMA_ORG_ID=
LEMMA_BASE_URL=https://api.lemma.work
LEMMA_GMAIL_AUTH_CONFIG=workspace-gmail
LEMMA_GMAIL_OPERATION=GMAIL_SEND_EMAIL

# Email — required for authorities to actually receive complaints
# Gmail: use an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
DEMO_EMAIL_TO=

# Escalation threshold in days
ESCALATION_DAYS=3

OPENAI_API_KEY=
