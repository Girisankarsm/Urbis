# MongoDB (used by FastAPI for images + demo-mode petition storage)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=civiclens

# Lemma (optional — set after `lemma pods import ./pod/civic-lens`)
LEMMA_TOKEN=
LEMMA_POD_ID=
LEMMA_ORG_ID=
LEMMA_BASE_URL=https://api.lemma.work

# Email (optional — if unset, emails are logged only)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=civiclens@demo.local
DEMO_EMAIL_TO=municipal-demo@example.com

# Escalation threshold in days
ESCALATION_DAYS=3

# Optional LLM for classification/drafting when Lemma agents are not connected
OPENAI_API_KEY=
