# Production API environment (copy to .env on your host or set in Render dashboard).
# Never commit real secrets to git.

ENVIRONMENT=production

# MongoDB Atlas — Network Access: allow 0.0.0.0/0 (or Render egress IPs)
MONGODB_URL=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/urbis?retryWrites=true&w=majority
MONGODB_DB=urbis

# Public URLs — replace with your deployed domains
API_BASE_URL=https://urbis-api.onrender.com
FRONTEND_URL=https://urbis.vercel.app
CORS_ORIGINS=https://urbis.vercel.app

# Session + cookies (Vercel proxies /api → Render; cookies are first-party on the frontend domain)
SESSION_SECRET=generate-a-long-random-string-here
COOKIE_SECURE=true
COOKIE_SAMESITE=lax

# Google OAuth — add redirect URI in Google Cloud Console:
#   https://<vercel-domain>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://urbis.vercel.app/api/auth/google/callback

# Lemma — use refresh token on hosted API (run lemma auth login locally, then sync)
LEMMA_REFRESH_TOKEN=
LEMMA_POD_ID=
LEMMA_ORG_ID=
LEMMA_BASE_URL=https://api.lemma.work

# Images (required on Render — local disk is ephemeral)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=urbis

# Email fallback (Gmail via OAuth is primary when users sign in)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
DEMO_EMAIL_REDIRECT=false

# Optional
OPENAI_API_KEY=
LEMMA_AGENT_TIMEOUT_SECONDS=25
RATE_LIMIT_ENABLED=true
